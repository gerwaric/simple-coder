# Agent authentication
AGENT_SECRET=change-me

# LLM configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-your-key-here
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=
LLM_THINKING_BUDGET=10000

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=simple_coder
POSTGRES_PASSWORD=simple_coder
POSTGRES_DB=simple_coder

# Optional — context window size for budget tracking (default: 128000)
LLM_MAX_TOKENS=128000

# Optional — for cloning private repos
GITHUB_TOKEN=

# Server
SERVER_PORT=3000

# Workspace directory (default: /workspace in Docker, .workspace for local dev)
WORKSPACE_DIR=
